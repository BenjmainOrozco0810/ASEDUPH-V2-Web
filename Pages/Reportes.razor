@page "/reportes"
@using ASEDUPH_V2_Web.Models
@using ASEDUPH_V2_Web.Services
@inject EstudianteService EstudianteService
@inject SolicitudBecaService SolicitudService
@inject BecaService BecaService
@inject BenefactorService BenefactorService
@inject AuthService AuthService

<PageTitle>Reportes - ASEDUPH</PageTitle>

<MudText Typo="Typo.h4" Style="color:#1565C0; font-weight:700;" Class="mb-1">
    Reportes e Indicadores
</MudText>
<MudText Typo="Typo.body2" Style="color:#546E7A;" Class="mb-6">
    Estadísticas generales del programa de becas — ASEDUPH
</MudText>

@if (cargando)
{
    <div class="d-flex justify-center pa-10">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else
{
    <!-- Indicadores numéricos -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Style="border-top:4px solid #1565C0; border-radius:8px; text-align:center;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h3" Style="color:#1565C0; font-weight:700;">
                        @totalEstudiantes
                    </MudText>
                    <MudText Typo="Typo.subtitle1" Style="color:#546E7A;">
                        Estudiantes Registrados
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Style="border-top:4px solid #1976D2; border-radius:8px; text-align:center;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h3" Style="color:#1976D2; font-weight:700;">
                        @totalSolicitudes
                    </MudText>
                    <MudText Typo="Typo.subtitle1" Style="color:#546E7A;">
                        Solicitudes Totales
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Style="border-top:4px solid #0288D1; border-radius:8px; text-align:center;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h3" Style="color:#0288D1; font-weight:700;">
                        @totalBecas
                    </MudText>
                    <MudText Typo="Typo.subtitle1" Style="color:#546E7A;">
                        Becas Activas
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Style="border-top:4px solid #0277BD; border-radius:8px; text-align:center;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h3" Style="color:#0277BD; font-weight:700;">
                        @totalBenefactores
                    </MudText>
                    <MudText Typo="Typo.subtitle1" Style="color:#546E7A;">
                        Benefactores Activos
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Tarjeta destacada: Total recaudado -->
    <MudCard Elevation="3" Style="border-radius:12px; background:linear-gradient(135deg, #1565C0, #0288D1); margin-bottom:24px;">
        <MudCardContent Class="pa-6">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.subtitle1" Style="color:#E3F2FD;">
                        Total Recaudado en Aportes
                    </MudText>
                    <MudText Typo="Typo.h3" Style="color:white; font-weight:700;">
                        Q @totalAportado.ToString("N2")
                    </MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.VolunteerActivism"
                         Style="color:rgba(255,255,255,0.5); font-size:5rem;" />
            </div>
        </MudCardContent>
    </MudCard>

    <MudGrid>
        <!-- Solicitudes por estado (barras CSS) -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Style="border-radius:12px;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:600;" Class="mb-4">
                        Solicitudes por Estado
                    </MudText>
                    @if (resumenSolicitudes.Any())
                    {
                        @foreach (var item in resumenSolicitudes)
                        {
                            <div class="mb-4">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <MudChip T="string" Size="Size.Small"
                                             Style="@GetEstadoStyle(item.Estado)">
                                        @item.Estado
                                    </MudChip>
                                    <MudText Typo="Typo.body2" Style="font-weight:700;">
                                        @item.Cantidad (@item.Porcentaje.ToString("F0")%)
                                    </MudText>
                                </div>
                                <div style="background-color:#ECEFF1; border-radius:8px; height:14px; width:100%; overflow:hidden;">
                                    <div style="@($"background-color:#1565C0; height:100%; width:{(int)item.Porcentaje}%; border-radius:8px; transition:width 0.5s;")"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center pa-6">
                            <MudText Style="color:#546E7A;">No hay datos disponibles</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Becas por nivel educativo (barras CSS) -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Style="border-radius:12px;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:600;" Class="mb-4">
                        Becas por Nivel Educativo
                    </MudText>
                    @if (resumenBecas.Any())
                    {
                        @foreach (var item in resumenBecas)
                        {
                            <div class="mb-4">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <MudText Typo="Typo.body2" Style="font-weight:600; color:#37474F;">
                                        @item.Estado
                                    </MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight:700;">
                                        @item.Cantidad (@item.Porcentaje.ToString("F0")%)
                                    </MudText>
                                </div>
                                <div style="background-color:#ECEFF1; border-radius:8px; height:14px; width:100%; overflow:hidden;">
                                    <div style="@($"background-color:#0288D1; height:100%; width:{(int)item.Porcentaje}%; border-radius:8px; transition:width 0.5s;")"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center pa-6">
                            <MudText Style="color:#546E7A;">No hay datos disponibles</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Aportes por Benefactor (barras CSS) -->
        <MudItem xs="12">
            <MudCard Elevation="2" Style="border-radius:12px;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:600;" Class="mb-4">
                        Aportes por Benefactor
                    </MudText>
                    @if (resumenAportes.Any())
                    {
                        @foreach (var item in resumenAportes)
                        {
                            <div class="mb-4">
                                <div class="d-flex justify-space-between align-center mb-1">
                                    <div class="d-flex align-center">
                                        <MudAvatar Style="background-color:#E3F2FD; color:#1565C0;
                                                          width:32px; height:32px; font-size:0.85rem;"
                                                   Class="mr-2">
                                            @item.Nombre.Substring(0, 1).ToUpper()
                                        </MudAvatar>
                                        <MudText Typo="Typo.body2" Style="font-weight:600; color:#37474F;">
                                            @item.Nombre
                                        </MudText>
                                    </div>
                                    <MudText Typo="Typo.body2" Style="font-weight:700; color:#2E7D32;">
                                        Q @item.Total.ToString("N2")
                                    </MudText>
                                </div>
                                <div style="background-color:#ECEFF1; border-radius:8px; height:14px; width:100%; overflow:hidden;">
                                    <div style="@($"background-color:#2E7D32; height:100%; width:{(int)item.Porcentaje}%; border-radius:8px; transition:width 0.5s;")"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center pa-6">
                            <MudText Style="color:#546E7A;">No hay aportes registrados</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Tabla resumen de solicitudes -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Style="border-radius:12px;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:600;" Class="mb-4">
                        Resumen de Solicitudes
                    </MudText>
                    <MudTable Items="@resumenSolicitudes" Dense="true" Elevation="0" Striped="true">
                        <HeaderContent>
                            <MudTh Style="color:#1565C0;">Estado</MudTh>
                            <MudTh Style="color:#1565C0;">Cantidad</MudTh>
                            <MudTh Style="color:#1565C0;">Porcentaje</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small"
                                         Style="@GetEstadoStyle(context.Estado)">
                                    @context.Estado
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2" Style="font-weight:700;">
                                    @context.Cantidad
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2">
                                    @context.Porcentaje.ToString("F1")%
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTFootRow>
                                <MudTd><b>Total</b></MudTd>
                                <MudTd><b>@totalSolicitudes</b></MudTd>
                                <MudTd><b>100%</b></MudTd>
                            </MudTFootRow>
                        </FooterContent>
                    </MudTable>
                </MudCardContent>
      </MudCard>
        </MudItem>

        <!-- Tabla resumen de becas -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Style="border-radius:12px;">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:600;" Class="mb-4">
                        Resumen de Becas por Nivel
                    </MudText>
                    <MudTable Items="@resumenBecas" Dense="true" Elevation="0" Striped="true">
                        <HeaderContent>
                            <MudTh Style="color:#1565C0;">Nivel Educativo</MudTh>
                            <MudTh Style="color:#1565C0;">Becas Activas</MudTh>
                            <MudTh Style="color:#1565C0;">Porcentaje</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudText Typo="Typo.body2">@context.Estado</MudText>
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2" Style="font-weight:700;">
                                    @context.Cantidad
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2">
                                    @context.Porcentaje.ToString("F1")%
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTFootRow>
                                <MudTd><b>Total</b></MudTd>
                                <MudTd><b>@totalBecas</b></MudTd>
                                <MudTd><b>100%</b></MudTd>
                            </MudTFootRow>
                        </FooterContent>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private bool cargando = true;
    private int totalEstudiantes;
    private int totalSolicitudes;
    private int totalBecas;
    private int totalBenefactores;
    private decimal totalAportado;

    private List<ResumenItem> resumenSolicitudes = new();
    private List<ResumenItem> resumenBecas = new();
    private List<ResumenAporte> resumenAportes = new();

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InicializarSesion();
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;

        var estudiantes = await EstudianteService.GetEstudiantes();
        var solicitudes = await SolicitudService.GetSolicitudes();
        var becas = await BecaService.GetBecas();
        var benefactores = await BenefactorService.GetBenefactores();
        var aportes = await BenefactorService.GetAportes();

        totalEstudiantes = estudiantes.Count;
        totalSolicitudes = solicitudes.Count;
        totalBecas = becas.Count;
        totalBenefactores = benefactores.Count;
        totalAportado = aportes.Sum(a => a.Monto);

        // Solicitudes por estado
        var datosSolicitudes = solicitudes
            .GroupBy(s => s.EstadoSolicitud)
            .ToDictionary(g => g.Key, g => g.Count());

        resumenSolicitudes = datosSolicitudes.Select(kv => new ResumenItem
        {
            Estado = kv.Key,
            Cantidad = kv.Value,
            Porcentaje = totalSolicitudes > 0 ? (kv.Value * 100.0 / totalSolicitudes) : 0
        }).OrderByDescending(r => r.Cantidad).ToList();

        // Becas por nivel educativo
        var datosBecas = becas
            .GroupBy(b => b.NivelEducativo ?? "Sin nivel")
            .ToDictionary(g => g.Key, g => g.Count());

        resumenBecas = datosBecas.Select(kv => new ResumenItem
        {
            Estado = kv.Key,
            Cantidad = kv.Value,
            Porcentaje = totalBecas > 0 ? (kv.Value * 100.0 / totalBecas) : 0
        }).OrderByDescending(r => r.Cantidad).ToList();

        // Aportes por benefactor
        var montoMaximo = aportes
            .GroupBy(a => a.Benefactor?.NombreCompleto ?? "Desconocido")
            .Select(g => g.Sum(a => a.Monto))
            .DefaultIfEmpty(0)
            .Max();

        resumenAportes = aportes
            .GroupBy(a => a.Benefactor?.NombreCompleto ?? "Desconocido")
            .Select(g => new ResumenAporte
            {
                Nombre = g.Key,
                Total = g.Sum(a => a.Monto),
                Porcentaje = montoMaximo > 0 ? (double)(g.Sum(a => a.Monto) * 100 / montoMaximo) : 0
            })
            .OrderByDescending(r => r.Total)
            .ToList();

        cargando = false;
    }

    private string GetEstadoStyle(string estado) => estado switch
    {
        "Pendiente" => "background-color:#FFF8E1; color:#F57C00;",
        "En Evaluación" => "background-color:#E3F2FD; color:#1565C0;",
        "Aprobada" => "background-color:#E8F5E9; color:#2E7D32;",
        "Rechazada" => "background-color:#FFEBEE; color:#C62828;",
        "Cancelada" => "background-color:#F5F5F5; color:#546E7A;",
        _ => "background-color:#F5F5F5; color:#546E7A;"
    };

    private class ResumenItem
    {
        public string Estado { get; set; } = string.Empty;
        public int Cantidad { get; set; }
        public double Porcentaje { get; set; }
    }

    private class ResumenAporte
    {
        public string Nombre { get; set; } = string.Empty;
        public decimal Total { get; set; }
        public double Porcentaje { get; set; }
    }
}
