@page "/seguimiento"
@using ASEDUPH_V2_Web.Models
@using ASEDUPH_V2_Web.Services
@inject SeguimientoAcademicoService SeguimientoService
@inject ISnackbar Snackbar

<PageTitle>Seguimiento Académico - ASEDUPH</PageTitle>

<!-- Encabezado -->
<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="color:#1565C0; font-weight:700;">
            Seguimiento Académico
        </MudText>
        <MudText Typo="Typo.body2" Style="color:#546E7A;">
            Control del rendimiento académico de los becados — ASEDUPH
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Style="background-color:#1565C0; color:white;"
               StartIcon="@Icons.Material.Filled.TrendingUp"
               OnClick="AbrirFormularioNuevo"
               Size="Size.Large">
        Nuevo Seguimiento
    </MudButton>
</div>

<!-- Filtros -->
<MudCard Elevation="2" Style="border-radius:12px; margin-bottom:24px;">
    <MudCardContent Class="pa-4">
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="busqueda"
                              Placeholder="Buscar por nombre del estudiante..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Clearable="true"
                              Immediate="true"
                               />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect @bind-Value="filtroEstado"
                           Label="Filtrar por estado"
                           Variant="Variant.Outlined"
                           
                           Clearable="true">
                    <MudSelectItem Value="@("Aprobado")">Aprobado</MudSelectItem>
                    <MudSelectItem Value="@("Reprobado")">Reprobado</MudSelectItem>
                    <MudSelectItem Value="@("En Curso")">En Curso</MudSelectItem>
                    <MudSelectItem Value="@("Retirado")">Retirado</MudSelectItem>
                    <MudSelectItem Value="@("Finalizado")">Finalizado</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<!-- Tabla -->
<MudCard Elevation="2" Style="border-radius:12px;">
    <MudCardContent Class="pa-0">
        @if (cargando)
        {
            <div class="d-flex justify-center pa-10">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!seguimientosFiltrados.Any())
        {
            <div class="text-center pa-10">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                         Style="color:#90CAF9; font-size:4rem;" Class="mb-2" />
                <MudText Typo="Typo.h6" Style="color:#546E7A;">
                    No se encontraron seguimientos académicos
                </MudText>
            </div>
        }
        else
        {
            <MudTable Items="@seguimientosFiltrados"
                      Hover="true"
                      Striped="true"
                      Elevation="0">
                <HeaderContent>
                    <MudTh Style="color:#1565C0; font-weight:700;">Estudiante</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Año</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Nivel</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Grado</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Promedio</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Estado</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Centro Educativo</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <div class="d-flex align-center">
                            <MudAvatar Style="background-color:#E3F2FD; color:#1565C0;
                                              width:32px; height:32px; font-size:0.85rem;"
                                       Class="mr-2">
                                @(context.Estudiante?.NombreCompleto.Substring(0, 1).ToUpper() ?? "?")
                            </MudAvatar>
                            <MudText Typo="Typo.body2" Style="font-weight:600;">
                                @(context.Estudiante?.NombreCompleto ?? "Sin nombre")
                            </MudText>
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@context.Anio</MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@(context.NivelEducativo ?? "--")</MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@(context.Grado ?? "--")</MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2"
                                 Style="@GetPromedioStyle(context.Promedio)">
                            @(context.Promedio?.ToString("F2") ?? "--")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small"
                                 Style="@GetEstadoStyle(context.EstadoAcademico)">
                            @(context.EstadoAcademico ?? "--")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">
                            @(context.CentroEducativo?.Nombre ?? "--")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Style="color:#1565C0;"
                                       Size="Size.Small"
                                       OnClick="@(() => AbrirFormularioEditar(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Style="color:#C62828;"
                                       Size="Size.Small"
                                       OnClick="@(() => EliminarSeguimiento(context))"
                                       Title="Eliminar" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

<!-- Dialog Formulario -->
<MudDialog @bind-Visible="mostrarFormulario" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:700;">
            @(esNuevo ? "Nuevo Seguimiento Académico" : "Editar Seguimiento")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="segForm.EstudianteId"
                           Label="Estudiante"
                           Variant="Variant.Outlined"
                           
                           Required="true">
                    @foreach (var e in estudiantes)
                    {
                        <MudSelectItem Value="@e.EstudianteId">@e.NombreCompleto</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="segForm.BecaId"
                           Label="Beca asociada"
                           Variant="Variant.Outlined"
                           >
                    @foreach (var b in becas)
                    {
                        <MudSelectItem Value="@((int?)b.BecaId)">
                            #@b.BecaId - @(b.Estudiante?.NombreCompleto ?? "Sin nombre")
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="segForm.Anio"
                                 Label="Año"
                                 Variant="Variant.Outlined"
                                 Min="2000" Max="2100"
                                 T="int"
                                  />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="segForm.NivelEducativo"
                           Label="Nivel educativo"
                           Variant="Variant.Outlined"
                           >
                    <MudSelectItem Value="@("Preprimaria")">Preprimaria</MudSelectItem>
                    <MudSelectItem Value="@("Primaria")">Primaria</MudSelectItem>
                    <MudSelectItem Value="@("Básicos")">Básicos</MudSelectItem>
                    <MudSelectItem Value="@("Diversificado")">Diversificado</MudSelectItem>
                    <MudSelectItem Value="@("Universidad")">Universidad</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="segForm.Grado"
                              Label="Grado"
                              Variant="Variant.Outlined"
                               />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="segForm.Promedio"
                                 Label="Promedio"
                                 Variant="Variant.Outlined"
                                 Min="0" Max="100"
                                 T="decimal?"
                                  />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="segForm.EstadoAcademico"
                           Label="Estado académico"
                           Variant="Variant.Outlined"
                           >
                    <MudSelectItem Value="@("Aprobado")">Aprobado</MudSelectItem>
                    <MudSelectItem Value="@("Reprobado")">Reprobado</MudSelectItem>
                    <MudSelectItem Value="@("En Curso")">En Curso</MudSelectItem>
                    <MudSelectItem Value="@("Retirado")">Retirado</MudSelectItem>
                    <MudSelectItem Value="@("Finalizado")">Finalizado</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="segForm.CentroEducativoId"
                           Label="Centro educativo"
                           Variant="Variant.Outlined"
                           >
                    @foreach (var c in centros)
                    {
                        <MudSelectItem Value="@((int?)c.CentroEducativoId)">@c.Nombre</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="segForm.Observaciones"
                              Label="Observaciones"
                              Variant="Variant.Outlined"
                              Lines="2"
                               />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CerrarFormulario"
                   Variant="Variant.Outlined"
                   Style="color:#546E7A; border-color:#546E7A;">
            Cancelar
        </MudButton>
        <MudButton OnClick="GuardarSeguimiento"
                   Variant="Variant.Filled"
                   Style="background-color:#1565C0; color:white;"
                   Disabled="@guardando">
            @if (guardando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Guardando...</span>
            }
            else
            {
                <span>@(esNuevo ? "Registrar" : "Actualizar")</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<SeguimientoAcademico> seguimientos = new();
    private List<Estudiante> estudiantes = new();
    private List<Beca> becas = new();
    private List<CentroEducativo> centros = new();
    private string busqueda = string.Empty;
    private string? filtroEstado;
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool esNuevo = true;
    private bool guardando = false;
    private SeguimientoAcademico segForm = new();

    private DialogOptions dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private IEnumerable<SeguimientoAcademico> seguimientosFiltrados => seguimientos.Where(s =>
        (string.IsNullOrWhiteSpace(busqueda) ||
         (s.Estudiante?.NombreCompleto.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)) &&
        (string.IsNullOrWhiteSpace(filtroEstado) || s.EstadoAcademico == filtroEstado));

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        seguimientos = await SeguimientoService.GetSeguimientos();
        estudiantes = await SeguimientoService.GetEstudiantes();
        becas = await SeguimientoService.GetBecas();
        centros = await SeguimientoService.GetCentros();
        cargando = false;
    }

    private void AbrirFormularioNuevo()
    {
        esNuevo = true;
        segForm = new SeguimientoAcademico
        {
            Anio = DateTime.Now.Year,
            EstadoAcademico = "En Curso"
        };
        mostrarFormulario = true;
    }

    private void AbrirFormularioEditar(SeguimientoAcademico seg)
    {
        esNuevo = false;
        segForm = new SeguimientoAcademico
        {
            SeguimientoAcademicoId = seg.SeguimientoAcademicoId,
            EstudianteId = seg.EstudianteId,
            BecaId = seg.BecaId,
            CentroEducativoId = seg.CentroEducativoId,
            Anio = seg.Anio,
            Grado = seg.Grado,
            NivelEducativo = seg.NivelEducativo,
            Promedio = seg.Promedio,
            EstadoAcademico = seg.EstadoAcademico,
            Observaciones = seg.Observaciones
        };
        mostrarFormulario = true;
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        segForm = new();
    }

    private async Task GuardarSeguimiento()
    {
        if (segForm.EstudianteId == 0)
        {
            Snackbar.Add("Debe seleccionar un estudiante.", Severity.Warning);
            return;
        }

        guardando = true;

        (bool exito, string mensaje) resultado;

        if (esNuevo)
            resultado = await SeguimientoService.CrearSeguimiento(segForm);
        else
            resultado = await SeguimientoService.ActualizarSeguimiento(
                segForm.SeguimientoAcademicoId, segForm);

        guardando = false;

        if (resultado.exito)
        {
            Snackbar.Add(resultado.mensaje, Severity.Success);
            CerrarFormulario();
            await CargarDatos();
        }
        else
        {
            Snackbar.Add(resultado.mensaje, Severity.Error);
        }
    }

    private async Task EliminarSeguimiento(SeguimientoAcademico seg)
    {
        var resultado = await SeguimientoService.EliminarSeguimiento(seg.SeguimientoAcademicoId);
        if (resultado.exito)
        {
            Snackbar.Add(resultado.mensaje, Severity.Success);
            await CargarDatos();
        }
        else
        {
            Snackbar.Add(resultado.mensaje, Severity.Error);
        }
    }

    private string GetPromedioStyle(decimal? promedio)
    {
        if (!promedio.HasValue) return "";
        if (promedio >= 75) return "color:#2E7D32; font-weight:700;";
        if (promedio >= 60) return "color:#F57C00; font-weight:700;";
        return "color:#C62828; font-weight:700;";
    }

    private string GetEstadoStyle(string? estado) => estado switch
    {
        "Aprobado" => "background-color:#E8F5E9; color:#2E7D32;",
        "Reprobado" => "background-color:#FFEBEE; color:#C62828;",
        "En Curso" => "background-color:#E3F2FD; color:#1565C0;",
        "Retirado" => "background-color:#FFF8E1; color:#F57C00;",
        "Finalizado" => "background-color:#F3E5F5; color:#6A1B9A;",
        _ => "background-color:#F5F5F5; color:#546E7A;"
    };
}
