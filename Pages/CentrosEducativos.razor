@page "/centros-educativos"
@using ASEDUPH_V2_Web.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Centros Educativos - ASEDUPH</PageTitle>

<!-- Encabezado -->
<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="color:#1565C0; font-weight:700;">
            Centros Educativos
        </MudText>
        <MudText Typo="Typo.body2" Style="color:#546E7A;">
            Gestión de centros educativos registrados — ASEDUPH
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Style="background-color:#1565C0; color:white;"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="AbrirFormularioNuevo"
               Size="Size.Large">
        Nuevo Centro
    </MudButton>
</div>

<!-- Buscador -->
<MudCard Elevation="2" Style="border-radius:12px; margin-bottom:24px;">
    <MudCardContent Class="pa-4">
        <MudTextField @bind-Value="busqueda"
                      Placeholder="Buscar por nombre o tipo..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Clearable="true"
                      Immediate="true" />
    </MudCardContent>
</MudCard>

@if (cargando)
{
    <div class="d-flex justify-center pa-10">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else if (!centrosFiltrados.Any())
{
    <MudCard Elevation="2" Style="border-radius:12px;">
        <MudCardContent Class="text-center pa-10">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance"
                     Style="color:#90CAF9; font-size:4rem;" Class="mb-2" />
            <MudText Typo="Typo.h6" Style="color:#546E7A;">
                No se encontraron centros educativos
            </MudText>
        </MudCardContent>
    </MudCard>
}
else
{
    <MudGrid>
        @foreach (var c in centrosFiltrados)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Style="border-radius:12px; border-top:4px solid #1565C0;">
                    <MudCardContent Class="pa-4">
                        <div class="d-flex align-center mb-3">
                            <MudAvatar Style="background-color:#1565C0; color:white;
                                              width:48px; height:48px; font-size:1.2rem;"
                                       Class="mr-3">
                                @c.Nombre.Substring(0, 1).ToUpper()
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:#1565C0;">
                                    @c.Nombre
                                </MudText>
                                <MudChip T="string" Size="Size.Small"
                                         Style="background-color:#E3F2FD; color:#1565C0;">
                                    @(c.TipoCentro ?? "Sin tipo")
                                </MudChip>
                            </div>
                        </div>
                        <MudDivider Class="mb-3" />
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Phone"
                                     Style="color:#546E7A; font-size:1rem;" Class="mr-2" />
                            <MudText Typo="Typo.body2" Style="color:#546E7A;">
                                @(c.Telefono ?? "Sin teléfono")
                            </MudText>
                        </div>
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn"
                                     Style="color:#546E7A; font-size:1rem;" Class="mr-2" />
                            <MudText Typo="Typo.body2" Style="color:#546E7A;">
                                @(c.Direccion ?? "Sin dirección")
                            </MudText>
                        </div>
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Circle"
                                     Style="@($"color:{(c.Estado == "Activo" ? "#2E7D32" : "#C62828")}; font-size:0.7rem;")"
                                     Class="mr-2" />
                            <MudText Typo="Typo.body2"
                                     Style="@($"color:{(c.Estado == "Activo" ? "#2E7D32" : "#C62828")};")">
                                @c.Estado
                            </MudText>
                        </div>
                    </MudCardContent>
                    <MudCardActions Class="pa-3 pt-0">
                        <MudButton Variant="Variant.Text"
                                   Style="color:#1565C0;"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="@(() => AbrirFormularioEditar(c))">
                            Editar
                        </MudButton>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Style="color:#C62828;" Size="Size.Small"
                                       OnClick="@(() => DesactivarCentro(c))" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<!-- Dialog -->
<MudDialog @bind-Visible="mostrarFormulario" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:700;">
            @(esNuevo ? "Nuevo Centro Educativo" : "Editar Centro Educativo")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="centroForm.Nombre"
                              Label="Nombre del centro educativo"
                              Variant="Variant.Outlined"
                              Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="centroForm.TipoCentro"
                           Label="Tipo de centro"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Público")">Público</MudSelectItem>
                    <MudSelectItem Value="@("Privado")">Privado</MudSelectItem>
                    <MudSelectItem Value="@("Cooperativa")">Cooperativa</MudSelectItem>
                    <MudSelectItem Value="@("Municipal")">Municipal</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="centroForm.Telefono"
                              Label="Teléfono"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="centroForm.Direccion"
                              Label="Dirección"
                              Variant="Variant.Outlined"
                              Lines="2" />
            </MudItem>
            @if (!esNuevo)
            {
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="centroForm.Estado"
                               Label="Estado"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Activo")">Activo</MudSelectItem>
                        <MudSelectItem Value="@("Inactivo")">Inactivo</MudSelectItem>
                    </MudSelect>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CerrarFormulario"
                   Variant="Variant.Outlined"
                   Style="color:#546E7A; border-color:#546E7A;">
            Cancelar
        </MudButton>
        <MudButton OnClick="GuardarCentro"
                   Variant="Variant.Filled"
                   Style="background-color:#1565C0; color:white;"
                   Disabled="@guardando">
            @if (guardando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Guardando...</span>
            }
            else
            {
                <span>@(esNuevo ? "Crear" : "Actualizar")</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CentroEducativo> centros = new();
    private string busqueda = string.Empty;
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool esNuevo = true;
    private bool guardando = false;
    private CentroEducativo centroForm = new();

    private DialogOptions dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private IEnumerable<CentroEducativo> centrosFiltrados => centros.Where(c =>
        string.IsNullOrWhiteSpace(busqueda) ||
        c.Nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
        (c.TipoCentro?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync() => await CargarCentros();

    private async Task CargarCentros()
    {
        cargando = true;
        try
        {
            var resultado = await Http.GetFromJsonAsync<List<CentroEducativo>>("api/CentrosEducativos");
            centros = resultado ?? new();
        }
        catch { centros = new(); }
        cargando = false;
    }

    private void AbrirFormularioNuevo()
    {
        esNuevo = true;
        centroForm = new CentroEducativo { Estado = "Activo" };
        mostrarFormulario = true;
    }

    private void AbrirFormularioEditar(CentroEducativo c)
    {
        esNuevo = false;
        centroForm = new CentroEducativo
        {
            CentroEducativoId = c.CentroEducativoId,
            Nombre = c.Nombre,
            Direccion = c.Direccion,
            Telefono = c.Telefono,
            TipoCentro = c.TipoCentro,
            Estado = c.Estado
        };
        mostrarFormulario = true;
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        centroForm = new();
    }

    private async Task GuardarCentro()
    {
        if (string.IsNullOrWhiteSpace(centroForm.Nombre))
        {
            Snackbar.Add("El nombre del centro es requerido.", Severity.Warning);
            return;
        }

        guardando = true;
        System.Net.Http.HttpResponseMessage response;

        if (esNuevo)
            response = await Http.PostAsJsonAsync("api/CentrosEducativos", centroForm);
        else
            response = await Http.PutAsJsonAsync(
                $"api/CentrosEducativos/{centroForm.CentroEducativoId}", centroForm);

        guardando = false;

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(esNuevo ? "Centro creado." : "Centro actualizado.", Severity.Success);
            CerrarFormulario();
            await CargarCentros();
        }
        else
        {
            Snackbar.Add("Error al guardar.", Severity.Error);
        }
    }

    private async Task DesactivarCentro(CentroEducativo c)
    {
        var response = await Http.DeleteAsync($"api/CentrosEducativos/{c.CentroEducativoId}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Centro desactivado.", Severity.Success);
            await CargarCentros();
        }
        else Snackbar.Add("Error al desactivar.", Severity.Error);
    }
}
