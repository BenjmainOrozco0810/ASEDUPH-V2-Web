@page "/renovaciones"
@using ASEDUPH_V2_Web.Models
@using ASEDUPH_V2_Web.Services
@inject RenovacionBecaService RenovacionService
@inject ISnackbar Snackbar

<PageTitle>Renovaciones de Beca - ASEDUPH</PageTitle>

<!-- Encabezado -->
<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="color:#1565C0; font-weight:700;">
            Renovaciones de Beca
        </MudText>
        <MudText Typo="Typo.body2" Style="color:#546E7A;">
            Gestión de renovaciones anuales de becas — ASEDUPH
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Style="background-color:#1565C0; color:white;"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="AbrirFormularioNuevo"
               Size="Size.Large">
        Nueva Renovación
    </MudButton>
</div>

<!-- Filtros -->
<MudCard Elevation="2" Style="border-radius:12px; margin-bottom:24px;">
    <MudCardContent Class="pa-4">
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="busqueda"
                              Placeholder="Buscar por nombre del estudiante..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Clearable="true"
                              Immediate="true"
                               />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect @bind-Value="filtroEstado"
                           Label="Filtrar por estado"
                           Variant="Variant.Outlined"
                           
                           Clearable="true">
                    <MudSelectItem Value="@("Pendiente")">Pendiente</MudSelectItem>
                    <MudSelectItem Value="@("En Evaluación")">En Evaluación</MudSelectItem>
                    <MudSelectItem Value="@("Aprobada")">Aprobada</MudSelectItem>
                    <MudSelectItem Value="@("Rechazada")">Rechazada</MudSelectItem>
                    <MudSelectItem Value="@("Cancelada")">Cancelada</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<!-- Tabla -->
<MudCard Elevation="2" Style="border-radius:12px;">
    <MudCardContent Class="pa-0">
        @if (cargando)
        {
            <div class="d-flex justify-center pa-10">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!renovacionesFiltradas.Any())
        {
            <div class="text-center pa-10">
                <MudIcon Icon="@Icons.Material.Filled.Refresh"
                         Style="color:#90CAF9; font-size:4rem;" Class="mb-2" />
                <MudText Typo="Typo.h6" Style="color:#546E7A;">
                    No se encontraron renovaciones
                </MudText>
            </div>
        }
        else
        {
            <MudTable Items="@renovacionesFiltradas"
                      Hover="true"
                      Striped="true"
                      Elevation="0">
                <HeaderContent>
                    <MudTh Style="color:#1565C0; font-weight:700;">#</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Estudiante</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Año Renovación</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Promedio Anterior</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Tipo Apoyo</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Estado</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Fecha Solicitud</MudTh>
                    <MudTh Style="color:#1565C0; font-weight:700;">Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Typo="Typo.body2" Style="color:#546E7A;">
                            #@context.RenovacionBecaId
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <div class="d-flex align-center">
                            <MudAvatar Style="background-color:#E3F2FD; color:#1565C0;
                                              width:32px; height:32px; font-size:0.85rem;"
                                       Class="mr-2">
                                @(context.Beca?.Estudiante?.NombreCompleto
                                    .Substring(0, 1).ToUpper() ?? "?")
                            </MudAvatar>
                            <MudText Typo="Typo.body2" Style="font-weight:600;">
                                @(context.Beca?.Estudiante?.NombreCompleto ?? "Sin nombre")
                            </MudText>
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@context.AnioRenovacion</MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2"
                                 Style="@GetPromedioStyle(context.PromedioFinalAnterior)">
                            @(context.PromedioFinalAnterior?.ToString("F2") ?? "--")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">
                            @(context.TipoApoyoRecibido ?? "--")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small"
                                 Style="@GetEstadoStyle(context.EstadoRenovacion)">
                            @context.EstadoRenovacion
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">
                            @(context.FechaSolicitud?.ToString("dd/MM/yyyy") ?? "--")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Style="color:#1565C0;"
                                       Size="Size.Small"
                                       OnClick="@(() => AbrirFormularioEditar(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                       Style="color:#F57C00;"
                                       Size="Size.Small"
                                       OnClick="@(() => AbrirCambioEstado(context))"
                                       Title="Cambiar estado" />
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                       Style="color:#C62828;"
                                       Size="Size.Small"
                                       OnClick="@(() => CancelarRenovacion(context))"
                                       Title="Cancelar" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

<!-- Dialog Formulario -->
<MudDialog @bind-Visible="mostrarFormulario" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:700;">
            @(esNuevo ? "Nueva Renovación de Beca" : "Editar Renovación")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="renovForm.BecaId"
                           Label="Beca"
                           Variant="Variant.Outlined"
                           
                           Required="true">
                    @foreach (var b in becas)
                    {
                        <MudSelectItem Value="@b.BecaId">
                            #@b.BecaId - @(b.Estudiante?.NombreCompleto ?? "Sin nombre")
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="renovForm.AnioRenovacion"
                                 Label="Año de renovación"
                                 Variant="Variant.Outlined"
                                 Min="2000" Max="2100"
                                 T="int"
                                  />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="renovForm.AnioCursadoAnterior"
                              Label="Año cursado anterior"
                              Variant="Variant.Outlined"
                              
                              Placeholder="Ej: 1ro Básico" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="renovForm.AnioACursar"
                              Label="Año a cursar"
                              Variant="Variant.Outlined"
                              
                              Placeholder="Ej: 2do Básico" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="renovForm.PromedioFinalAnterior"
                                 Label="Promedio final anterior"
                                 Variant="Variant.Outlined"
                                 Min="0" Max="100"
                                 T="decimal?"
                                  />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="renovForm.TipoApoyoRecibido"
                              Label="Tipo de apoyo recibido"
                              Variant="Variant.Outlined"
                               />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="renovForm.CentroEducativoAnteriorId"
                           Label="Centro educativo anterior"
                           Variant="Variant.Outlined"
                           >
                    @foreach (var c in centros)
                    {
                        <MudSelectItem Value="@((int?)c.CentroEducativoId)">@c.Nombre</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="renovForm.CentroEducativoNuevoId"
                           Label="Centro educativo nuevo"
                           Variant="Variant.Outlined"
                           >
                    @foreach (var c in centros)
                    {
                        <MudSelectItem Value="@((int?)c.CentroEducativoId)">@c.Nombre</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="renovForm.FechaSolicitud"
                               Label="Fecha de solicitud"
                               Variant="Variant.Outlined"
                               DateFormat="dd/MM/yyyy"
                                />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="renovForm.MotivoRenovacion"
                              Label="Motivo de renovación"
                              Variant="Variant.Outlined"
                              Lines="3"
                               />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="renovForm.Recomendaciones"
                              Label="Recomendaciones"
                              Variant="Variant.Outlined"
                              Lines="2"
                               />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CerrarFormulario"
                   Variant="Variant.Outlined"
                   Style="color:#546E7A; border-color:#546E7A;">
            Cancelar
        </MudButton>
        <MudButton OnClick="GuardarRenovacion"
                   Variant="Variant.Filled"
                   Style="background-color:#1565C0; color:white;"
                   Disabled="@guardando">
            @if (guardando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Guardando...</span>
            }
            else
            {
                <span>@(esNuevo ? "Registrar" : "Actualizar")</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog Cambio de Estado -->
<MudDialog @bind-Visible="mostrarCambioEstado" Options="dialogEstadoOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:700;">
            Cambiar Estado de Renovación
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Style="color:#546E7A;">
            Renovación de: <b>@renovSeleccionada?.Beca?.Estudiante?.NombreCompleto</b>
        </MudText>
        <MudSelect @bind-Value="nuevoEstado"
                   Label="Nuevo estado"
                   Variant="Variant.Outlined"
                   >
            <MudSelectItem Value="@("Pendiente")">Pendiente</MudSelectItem>
            <MudSelectItem Value="@("En Evaluación")">En Evaluación</MudSelectItem>
            <MudSelectItem Value="@("Aprobada")">Aprobada</MudSelectItem>
            <MudSelectItem Value="@("Rechazada")">Rechazada</MudSelectItem>
            <MudSelectItem Value="@("Cancelada")">Cancelada</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => mostrarCambioEstado = false)"
                   Variant="Variant.Outlined"
                   Style="color:#546E7A; border-color:#546E7A;">
            Cancelar
        </MudButton>
        <MudButton OnClick="GuardarCambioEstado"
                   Variant="Variant.Filled"
                   Style="background-color:#1565C0; color:white;">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<RenovacionBeca> renovaciones = new();
    private List<Beca> becas = new();
    private List<CentroEducativo> centros = new();
    private string busqueda = string.Empty;
    private string? filtroEstado;
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool mostrarCambioEstado = false;
    private bool esNuevo = true;
    private bool guardando = false;
    private RenovacionBeca renovForm = new();
    private RenovacionBeca? renovSeleccionada;
    private string nuevoEstado = string.Empty;

    private DialogOptions dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private DialogOptions dialogEstadoOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private IEnumerable<RenovacionBeca> renovacionesFiltradas => renovaciones.Where(r =>
        (string.IsNullOrWhiteSpace(busqueda) ||
         (r.Beca?.Estudiante?.NombreCompleto
             .Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)) &&
        (string.IsNullOrWhiteSpace(filtroEstado) || r.EstadoRenovacion == filtroEstado));

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        renovaciones = await RenovacionService.GetRenovaciones();
        becas = await RenovacionService.GetBecas();
        centros = await RenovacionService.GetCentros();
        cargando = false;
    }

    private void AbrirFormularioNuevo()
    {
        esNuevo = true;
        renovForm = new RenovacionBeca
        {
            AnioRenovacion = DateTime.Now.Year,
            FechaSolicitud = DateTime.Now,
            EstadoRenovacion = "Pendiente"
        };
        mostrarFormulario = true;
    }

    private void AbrirFormularioEditar(RenovacionBeca renov)
    {
        esNuevo = false;
        renovForm = new RenovacionBeca
        {
            RenovacionBecaId = renov.RenovacionBecaId,
            BecaId = renov.BecaId,
            CentroEducativoAnteriorId = renov.CentroEducativoAnteriorId,
            CentroEducativoNuevoId = renov.CentroEducativoNuevoId,
            AnioRenovacion = renov.AnioRenovacion,
            AnioCursadoAnterior = renov.AnioCursadoAnterior,
            AnioACursar = renov.AnioACursar,
            PromedioFinalAnterior = renov.PromedioFinalAnterior,
            TipoApoyoRecibido = renov.TipoApoyoRecibido,
            MotivoRenovacion = renov.MotivoRenovacion,
            EstadoRenovacion = renov.EstadoRenovacion,
            FechaSolicitud = renov.FechaSolicitud,
            Recomendaciones = renov.Recomendaciones,
            FechaDecision = renov.FechaDecision
        };
        mostrarFormulario = true;
    }

    private void AbrirCambioEstado(RenovacionBeca renov)
    {
        renovSeleccionada = renov;
        nuevoEstado = renov.EstadoRenovacion;
        mostrarCambioEstado = true;
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        renovForm = new();
    }

    private async Task GuardarRenovacion()
    {
        if (renovForm.BecaId == 0)
        {
            Snackbar.Add("Debe seleccionar una beca.", Severity.Warning);
            return;
        }

        guardando = true;

        (bool exito, string mensaje) resultado;

        if (esNuevo)
            resultado = await RenovacionService.CrearRenovacion(renovForm);
        else
            resultado = await RenovacionService.ActualizarRenovacion(
                renovForm.RenovacionBecaId, renovForm);

        guardando = false;

        if (resultado.exito)
        {
            Snackbar.Add(resultado.mensaje, Severity.Success);
            CerrarFormulario();
            await CargarDatos();
        }
        else
        {
            Snackbar.Add(resultado.mensaje, Severity.Error);
        }
    }

    private async Task GuardarCambioEstado()
    {
        if (renovSeleccionada == null) return;

        var resultado = await RenovacionService.CambiarEstado(
            renovSeleccionada.RenovacionBecaId, nuevoEstado);

        if (resultado.exito)
        {
            Snackbar.Add(resultado.mensaje, Severity.Success);
            mostrarCambioEstado = false;
            await CargarDatos();
        }
        else
        {
            Snackbar.Add(resultado.mensaje, Severity.Error);
        }
    }

    private async Task CancelarRenovacion(RenovacionBeca renov)
    {
        var resultado = await RenovacionService.CancelarRenovacion(renov.RenovacionBecaId);
        if (resultado.exito)
        {
            Snackbar.Add(resultado.mensaje, Severity.Success);
            await CargarDatos();
        }
        else
        {
            Snackbar.Add(resultado.mensaje, Severity.Error);
        }
    }

    private string GetPromedioStyle(decimal? promedio)
    {
        if (!promedio.HasValue) return "";
        if (promedio >= 75) return "color:#2E7D32; font-weight:700;";
        if (promedio >= 60) return "color:#F57C00; font-weight:700;";
        return "color:#C62828; font-weight:700;";
    }

    private string GetEstadoStyle(string estado) => estado switch
    {
        "Pendiente" => "background-color:#FFF8E1; color:#F57C00;",
        "En Evaluación" => "background-color:#E3F2FD; color:#1565C0;",
        "Aprobada" => "background-color:#E8F5E9; color:#2E7D32;",
        "Rechazada" => "background-color:#FFEBEE; color:#C62828;",
        "Cancelada" => "background-color:#F5F5F5; color:#546E7A;",
        _ => "background-color:#F5F5F5; color:#546E7A;"
    };
}
