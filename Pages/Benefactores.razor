@page "/benefactores"
@using ASEDUPH_V2_Web.Models
@using ASEDUPH_V2_Web.Services
@using System.Text.RegularExpressions
@inject BenefactorService BenefactorService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Benefactores - ASEDUPH</PageTitle>

<!-- Encabezado -->
<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="color:#1565C0; font-weight:700;">
            Benefactores
        </MudText>
        <MudText Typo="Typo.body2" Style="color:#546E7A;">
            Ángeles por la educación — ASEDUPH
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Style="background-color:#1565C0; color:white;"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="AbrirFormularioNuevo"
               Size="Size.Large">
        Nuevo Benefactor
    </MudButton>
</div>

<!-- Buscador -->
<MudCard Elevation="2" Style="border-radius:12px; margin-bottom:24px;">
    <MudCardContent Class="pa-4">
        <MudTextField @bind-Value="busqueda"
                      Placeholder="Buscar por nombre, correo o tipo..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Clearable="true"
                      Immediate="true" />
    </MudCardContent>
</MudCard>

@if (cargando)
{
    <div class="d-flex justify-center pa-10">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else if (!benefactoresFiltrados.Any())
{
    <MudCard Elevation="2" Style="border-radius:12px;">
        <MudCardContent Class="text-center pa-10">
            <MudIcon Icon="@Icons.Material.Filled.Favorite"
                     Style="color:#90CAF9; font-size:4rem;" Class="mb-2" />
            <MudText Typo="Typo.h6" Style="color:#546E7A;">
                No se encontraron benefactores
            </MudText>
        </MudCardContent>
    </MudCard>
}
else
{
    <!-- Tarjetas -->
    <MudGrid>
        @foreach (var b in benefactoresFiltrados)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Style="border-radius:12px; border-top:4px solid #1565C0;">
                    <MudCardContent Class="pa-4">
                        <div class="d-flex align-center mb-3">
                            <MudAvatar Style="background-color:#1565C0; color:white;
                                              width:48px; height:48px; font-size:1.2rem;"
                                       Class="mr-3">
                                @b.NombreCompleto.Substring(0, 1).ToUpper()
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:#1565C0;">
                                    @b.NombreCompleto
                                </MudText>
                                <MudChip T="string" Size="Size.Small"
                                         Style="background-color:#E3F2FD; color:#1565C0;">
                                    @(b.TipoBenefactor ?? "Sin tipo")
                                </MudChip>
                            </div>
                        </div>
                        <MudDivider Class="mb-3" />
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Phone"
                                     Style="color:#546E7A; font-size:1rem;" Class="mr-2" />
                            <MudText Typo="Typo.body2" Style="color:#546E7A;">
                                @(b.Telefono ?? "Sin teléfono")
                            </MudText>
                        </div>
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Email"
                                     Style="color:#546E7A; font-size:1rem;" Class="mr-2" />
                            <MudText Typo="Typo.body2" Style="color:#546E7A;">
                                @(b.CorreoElectronico ?? "Sin correo")
                            </MudText>
                        </div>
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Circle"
                                     Style="@($"color:{(b.Estado == "Activo" ? "#2E7D32" : "#C62828")}; font-size:0.7rem;")"
                                     Class="mr-2" />
                            <MudText Typo="Typo.body2"
                                     Style="@($"color:{(b.Estado == "Activo" ? "#2E7D32" : "#C62828")};")">
                                @b.Estado
                            </MudText>
                        </div>
                    </MudCardContent>
                    <MudCardActions Class="pa-3 pt-0">
                        <MudButton Variant="Variant.Text"
                                   Style="color:#1565C0;"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="@(() => AbrirFormularioEditar(b))">
                            Editar
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   Style="color:#2E7D32;"
                                   StartIcon="@Icons.Material.Filled.Payment"
                                   OnClick="@(() => Navigation.NavigateTo($"/aportes/{b.BenefactorId}"))">
                            Aportes
                        </MudButton>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Style="color:#C62828;" Size="Size.Small"
                                       OnClick="@(() => DesactivarBenefactor(b))" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<!-- Dialog Formulario -->
<MudDialog @bind-Visible="mostrarFormulario" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#1565C0; font-weight:700;">
            @(esNuevo ? "Nuevo Benefactor" : "Editar Benefactor")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="benefactorForm.NombreCompleto"
                              Label="Nombre completo"
                              Variant="Variant.Outlined"
                              Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="benefactorForm.TipoBenefactor"
                           Label="Tipo de benefactor"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Padrino")">Padrino</MudSelectItem>
                    <MudSelectItem Value="@("Donante")">Donante</MudSelectItem>
                    <MudSelectItem Value="@("Voluntario")">Voluntario</MudSelectItem>
                    <MudSelectItem Value="@("Empresa")">Empresa</MudSelectItem>
                    <MudSelectItem Value="@("Otro")">Otro</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="benefactorForm.Telefono"
                              Label="Teléfono"
                              Variant="Variant.Outlined"
                              MaxLength="8"
                              Validation="@(new Func<string, string?>(ValidarTelefono))"
                              HelperText="8 dígitos"
                              Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="benefactorForm.CorreoElectronico"
                              Label="Correo electrónico"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Validation="@(new Func<string, string?>(ValidarCorreo))"
                              Immediate="true" />
            </MudItem>
            @if (!esNuevo)
            {
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="benefactorForm.Estado"
                               Label="Estado"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Activo")">Activo</MudSelectItem>
                        <MudSelectItem Value="@("Inactivo")">Inactivo</MudSelectItem>
                    </MudSelect>
                </MudItem>
            }
            <MudItem xs="12">
                <MudTextField @bind-Value="benefactorForm.Direccion"
                              Label="Dirección"
                              Variant="Variant.Outlined"
                              Lines="2" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CerrarFormulario"
                   Variant="Variant.Outlined"
                   Style="color:#546E7A; border-color:#546E7A;">
            Cancelar
        </MudButton>
        <MudButton OnClick="GuardarBenefactor"
                   Variant="Variant.Filled"
                   Style="background-color:#1565C0; color:white;"
                   Disabled="@guardando">
            @if (guardando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Guardando...</span>
            }
            else
            {
                <span>@(esNuevo ? "Crear" : "Actualizar")</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Benefactor> benefactores = new();
    private string busqueda = string.Empty;
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool esNuevo = true;
    private bool guardando = false;
    private Benefactor benefactorForm = new();

    private DialogOptions dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    // ── Validaciones (Guatemala) ──────────────────────────────────────
    private string? ValidarTelefono(string telefono)
    {
        if (string.IsNullOrWhiteSpace(telefono)) return null; // opcional
        if (!Regex.IsMatch(telefono, @"^\d{8}$"))
            return "El teléfono debe tener 8 dígitos numéricos.";
        return null;
    }

    private string? ValidarCorreo(string correo)
    {
        if (string.IsNullOrWhiteSpace(correo)) return null; // opcional
        if (!Regex.IsMatch(correo, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            return "Ingrese un correo electrónico válido.";
        return null;
    }

    private IEnumerable<Benefactor> benefactoresFiltrados => benefactores.Where(b =>
        string.IsNullOrWhiteSpace(busqueda) ||
        b.NombreCompleto.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
        (b.CorreoElectronico?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (b.TipoBenefactor?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await CargarBenefactores();
    }

    private async Task CargarBenefactores()
    {
        cargando = true;
        benefactores = await BenefactorService.GetBenefactores();
        cargando = false;
    }

    private void AbrirFormularioNuevo()
    {
        esNuevo = true;
        benefactorForm = new Benefactor { Estado = "Activo" };
        mostrarFormulario = true;
    }

    private void AbrirFormularioEditar(Benefactor b)
    {
        esNuevo = false;
        benefactorForm = new Benefactor
        {
            BenefactorId = b.BenefactorId,
            NombreCompleto = b.NombreCompleto,
            Telefono = b.Telefono,
            CorreoElectronico = b.CorreoElectronico,
            Direccion = b.Direccion,
            TipoBenefactor = b.TipoBenefactor,
            Estado = b.Estado
        };
        mostrarFormulario = true;
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        benefactorForm = new();
    }

    private async Task GuardarBenefactor()
    {
        if (string.IsNullOrWhiteSpace(benefactorForm.NombreCompleto))
        {
            Snackbar.Add("El nombre del benefactor es requerido.", Severity.Warning);
            return;
        }

        // ── Validaciones de formato antes de guardar ──────────────────
        if (ValidarTelefono(benefactorForm.Telefono ?? "") is string errTel)
        {
            Snackbar.Add(errTel, Severity.Warning);
            return;
        }
        if (ValidarCorreo(benefactorForm.CorreoElectronico ?? "") is string errCorreo)
        {
            Snackbar.Add(errCorreo, Severity.Warning);
            return;
        }

        guardando = true;
        (bool exito, string mensaje) resultado;

        if (esNuevo)
            resultado = await BenefactorService.CrearBenefactor(benefactorForm);
        else
            resultado = await BenefactorService.ActualizarBenefactor(
                benefactorForm.BenefactorId, benefactorForm);

        guardando = false;

        if (resultado.exito)
        {
            Snackbar.Add(resultado.mensaje, Severity.Success);
            CerrarFormulario();
            await CargarBenefactores();
        }
        else
        {
            Snackbar.Add(resultado.mensaje, Severity.Error);
        }
    }

    private async Task DesactivarBenefactor(Benefactor b)
    {
        var resultado = await BenefactorService.DesactivarBenefactor(b.BenefactorId);
        if (resultado.exito)
        {
            Snackbar.Add(resultado.mensaje, Severity.Success);
            await CargarBenefactores();
        }
        else
        {
            Snackbar.Add(resultado.mensaje, Severity.Error);
        }
    }
}
